class Rectangle:
    def __init__(self,lenght,height):
     self.height=height
     self.lenght=lenght
    def Area(self):
        return self.height*self.lenght
    def Perimetr(self):
        return 2*(self.height+self.lenght)
    

class Bank:
    def __init__(self,name,balance):
         self.name=name
         self.balance=balance
    def deposit(self,amount):
        self.balance += amount
    def withdraw(self,amount):
        if amount > 0:
            self.balance -=amount
        else:
            print("Нету денег, бомж")
    def checkbalance(self):
        return self.balance
    

class Book:
    def __init__(self,name,author,pages):
        self.name=name
        self.author=author
        self.pages=pages
    def is_long(self):
        return self.pages >300

class Car:
    def __init__(self,brand,speed):
         self.brand=brand
         self.speed=speed
    def accelerate(self,value):
        self.speed += value
    def brake(self,value):
        if self.speed > 0:
            self.speed -= value
        else:
            print("Скорости нету")
    
